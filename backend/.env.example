# --- LOCAL (usa uno de los dos) ---
# Ruta al serviceAccount.json (desarrollo local)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# --- RAILWAY / RENDER (pega el contenido JSON completo del serviceAccount) ---
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# API key de Anthropic (https://console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Opcional: modelo de Claude (default claude-sonnet-4-6)
# CLAUDE_MODEL=claude-opus-4-8
